# Google OAuth (frontend-only popup flow)
VITE_GOOGLE_CLIENT_ID=

# Kakao OAuth (redirect flow + backend exchange)
VITE_KAKAO_REST_API_KEY=

# Naver OAuth (redirect flow + backend exchange)
VITE_NAVER_CLIENT_ID=

# Option 1: set each backend exchange endpoint explicitly
VITE_KAKAO_EXCHANGE_ENDPOINT=
VITE_NAVER_EXCHANGE_ENDPOINT=

# Option 2: set a shared base URL and use /kakao/exchange, /naver/exchange underneath it
# VITE_OAUTH_PROXY_BASE_URL=https://your-api.example.com/oauth
