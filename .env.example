# Frontend env
VITE_GOOGLE_CLIENT_ID=
VITE_KAKAO_REST_API_KEY=
VITE_NAVER_CLIENT_ID=

# Optional: override frontend exchange endpoints.
# If omitted, the app calls /api/oauth/kakao/exchange and /api/oauth/naver/exchange.
# VITE_OAUTH_PROXY_BASE_URL=/api/oauth
# VITE_KAKAO_EXCHANGE_ENDPOINT=
# VITE_NAVER_EXCHANGE_ENDPOINT=

# Server env for the included exchange handlers
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
